# Custom Kafka Connect image:
#   - debezium/connect:2.6  →  Debezium MySQL connector is already built in
#   - MongoDB Kafka connector added on top via Maven Central
FROM debezium/connect:2.6

USER root

RUN curl -L \
    "https://repo1.maven.org/maven2/org/mongodb/kafka/mongo-kafka-connect/1.13.0/mongo-kafka-connect-1.13.0-all.jar" \
    -o /kafka/connect/mongo-kafka-connect-1.13.0-all.jar

USER kafka
